set ACTION=%1
if "%1" == "" set ACTION=make

echo -^> %ACTION% vendor-win-iconv

goto StepX
:cmdX
%*
if errorlevel 1 goto cmdXError
goto :eof
:cmdXError
echo "Error: %ACTION%"
exit 1
:StepX

call :cmdX xyo-cc --make=%ACTION% --exe vendor-win-iconv.make
